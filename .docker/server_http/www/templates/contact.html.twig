{% extends "base.html.twig" %}

{% block content %}
<div style="text-align: center;">
    <h1>{{ __('Nous contacter') }}</h1>
    <div style="text-align: left;" class="alert alert-success">
        <strong>{{ __('Vous avez trouvé un bogue ?') }}</strong><br />
        {{ __('Vous avez trouvé un bogue sur notre site? Envoyez nous l\'adresse, notre équipe technique analysera votre demande dans les plus brefs délais.') }}
    </div>
    <form action="/contact" method="post">
        <label for="form_contact">{{ __('Url :') }} <input type="url" name="url" id="form_contact"></label>
        <button id="btn_contact" type="submit">{{ __('Envoyer') }}</button>
    </form>
</div>
{% endblock %}
